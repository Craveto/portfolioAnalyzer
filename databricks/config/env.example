# Databricks connection
DBX_HOST=your-workspace.cloud.databricks.com
DBX_HTTP_PATH=/sql/1.0/warehouses/your-warehouse-id
DBX_TOKEN=your_databricks_pat_token_here
DBX_CATALOG=portfolio_analyzer
DBX_BRONZE_SCHEMA=bronze
DBX_SILVER_SCHEMA=silver
DBX_GOLD_SCHEMA=gold

# Supabase / Postgres source for Databricks JDBC
SUPABASE_DB_HOST=your-supabase-host.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=your-db-user
SUPABASE_DB_PASSWORD=your-db-password

# News / market providers
NEWS_PROVIDER=yfinance
NEWS_PROVIDER_KEY=
MARKET_PROVIDER=yfinance

# Backend provider selection
STOCK_INSIGHT_PROVIDER=databricks
