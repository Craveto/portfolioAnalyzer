DJANGO_SECRET_KEY=replace-with-a-strong-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=portfolio-analyzer-api.azurewebsites.net

# Recommended smooth Azure path for App Service:
# Use Azure Database for PostgreSQL OR Supabase (Postgres)
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE

# Frontend origin (Azure Static Web Apps domain)
CORS_ALLOWED_ORIGINS=https://portfolio-analyzer-web.azurestaticapps.net
CSRF_TRUSTED_ORIGINS=https://portfolio-analyzer-web.azurestaticapps.net

# Live data / hosted reliability
FUNDAMENTALS_PROVIDER=auto
RAPIDAPI_KEY=
MARKET_WARMUP_TOKEN=replace-with-random-token

# Optional tuning
DJANGO_STATIC_ROOT=/home/site/wwwroot/staticfiles
YFINANCE_CACHE_DIR=/home/site/wwwroot/.cache/yfinance
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=180
